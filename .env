# 服务器端口
PORT=3000

# ========================================
# 本地开发环境配置 (Docker MongoDB)
# ========================================
MONGO_HOST=localhost:27017
MONGO_DATABASE=test

# ========================================
# 本地开发环境配置 (无认证 MongoDB)
# 使用这个配置时,注释掉上面的 MONGO_USER 和 MONGO_PASSWORD
# ========================================
# MONGO_USER=
# MONGO_PASSWORD=
# MONGO_HOST=localhost:27017
# MONGO_DATABASE=booking_dev

# ========================================
# 生产环境配置 (MongoDB Atlas 云数据库)
# ========================================
# MONGO_USER=your_username
# MONGO_PASSWORD=your_password
# MONGO_HOST=your_cluster.mongodb.net
# MONGO_DATABASE=booking_prod
